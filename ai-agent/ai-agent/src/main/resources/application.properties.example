spring.application.name=ai-agent

# OpenRouter config (OpenAI-compatible)
spring.ai.openai.base-url=https://openrouter.ai/api
spring.ai.openai.api-key=sk-or-v1-YOUR_API_KEY_HERE
#spring.ai.openai.chat.options.model=google/gemma-3n-e4b-it:free
#spring.ai.openai.chat.options.model=google/gemma-3-27b-it:free
spring.ai.openai.chat.options.model=google/gemma-3n-e2b-it:free
spring.ai.openai.chat.options.temperature=0.7

# Server
server.port=8080

# Enable multipart uploads
spring.servlet.multipart.enabled=true
# Standard limits
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
# Ensure Tomcat doesn't reject the parts
server.tomcat.max-part-count=20

# Pinecone config (optional)
#pinecone api = YOUR_PINECONE_API_KEY_HERE
#pinecode host = YOUR_PINECONE_HOST_URL_HERE

# MySQL configuration
spring.datasource.url=jdbc:mysql://localhost:3306/resumematcher
spring.datasource.username=root
spring.datasource.password=YOUR_DATABASE_PASSWORD_HERE
spring.jpa.hibernate.ddl-auto=update
